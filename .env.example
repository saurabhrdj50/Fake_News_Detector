# =============================================================
# Fake News Detector - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# Gemini AI API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Model Path (optional, defaults to backend/models/)
# MODEL_PATH=backend/models/fake_news_lstm_model.h5

# Tokenizer Path (optional, defaults to backend/models/)
# TOKENIZER_PATH=backend/models/tokenizer.pkl

# Flask/Debug settings (for development)
DEBUG=true
